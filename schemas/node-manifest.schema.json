{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "10G Node Manifest",
  "type": "object",
  "required": ["node_id", "capabilities", "attestation"],
  "properties": {
    "node_id": {"type": "string"},
    "capabilities": {
      "type": "array",
      "items": {"type": "string"}
    },
    "attestation": {"type": "object"}
  }
}